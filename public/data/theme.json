{
  "theme": {
    "version": "1.0.0",
    "apiVersion": "1.2",
    "displayName": "Corporate Tailwind",
    "description": "Small business theme with basic Tailwind styling.",
    "language": "typescript",
    "imageUrl": "https://cdn.jsdelivr.net/gh/builtjs/builtjs-theme-corporate-tailwind/public/images/theme/theme.png",
    "repoName": "builtjs/builtjs-theme-corporate-tailwind",
    "gitProvider": "github",
    "repoUrl": "https://github.com/builtjs/builtjs-theme-corporate-tailwind",
    "demoUrl": "https://builtjs-theme-corporate-tailwind.vercel.app",
    "modules": [
      {
        "slug": "main"
      },
      {
        "slug": "services"
      },
      {
        "slug": "features"
      },
      {
        "slug": "Benefits"
      },
      {
        "slug": "about"
      },
      {
        "slug": "contact"
      }
    ],
    "config": {
      "frontend": {
        "project": {
          "main": {
            "name": "nextjs",
            "config": {
              "router": "pages"
            }
          },
          "css": {
            "name": "tailwind"
          }
        },
        "node": {
          "dependencies": [
            "@fisch0920/use-dark-mode"
          ],
          "devDependencies": [
            "autoprefixer",
            "postcss",
            "tailwindcss"
          ]
        }
      },
      "backend": {
        "project": {
          "main": {
            "name": "strapi"
          }
        }
      }
    }
  }
}
